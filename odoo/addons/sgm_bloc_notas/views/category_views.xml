<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="sgm_view_category_tree" model="ir.ui.view">
        <field name="name">sgm_bloc_notas.category.tree</field>
        <field name="model">sgm_bloc_notas.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="sgm_view_category_form" model="ir.ui.view">
        <field name="name">sgm_bloc_notas.category.form</field>
        <field name="model">sgm_bloc_notas.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
