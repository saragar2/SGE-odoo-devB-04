<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="sgm_view_tag_tree" model="ir.ui.view">
        <field name="name">sgm.tag.tree</field>
        <field name="model">sgm.tag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="color"/>
            </tree>
        </field>
    </record>

    <record id="sgm_view_tag_form" model="ir.ui.view">
        <field name="name">sgm.tag.form</field>
        <field name="model">sgm.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
