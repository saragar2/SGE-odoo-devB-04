<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Vista de lista -->
    <record id="sgm_bloc_notas_view_note_tree" model="ir.ui.view">
        <field name="name">sgm_bloc_notas.note.tree</field>
        <field name="model">sgm_bloc_notas.note</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="owner_id"/>
                <field name="category_id"/>
                <field name="is_public"/>
                <field name="last_update"/>
            </tree>
        </field>
    </record>

    <!-- Vista de formulario -->
    <record id="sgm_bloc_notas_view_note_form" model="ir.ui.view">
        <field name="name">sgm_bloc_notas.note.form</field>
        <field name="model">sgm_bloc_notas.note</field>
        <field name="arch" type="xml">
            <form string="Nota compartida">
                <sheet>

                    <!-- Imagen -->
                    <div class="oe_title">
                        <field name="image" widget="image" class="oe_avatar"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="owner_id"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="is_public"/>
                            <field name="tag_ids" widget="many2many_tags">
                                <tree>
                                    <field name="name"/>
                                </tree>
                            </field>
                        </group>
                    </group>

                    <notebook>
                        <page string="Contenido">
                            <field name="content"/>
                        </page>

                        <page string="Líneas">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="title"/>
                                    <field name="description"/>
                                    <field name="done"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>

                <!-- Seguimiento y actividades -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

</odoo>
